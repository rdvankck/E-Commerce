{
  "name": "@ecommerce/database",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --fix",
    "test": "jest",
    "db:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "db:create-migration": "typeorm-ts-node-commonjs migration:create"
  },
  "dependencies": {
    "typeorm": "^0.3.20",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "uuid": "^9.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.5.0",
    "ts-node": "^10.9.0"
  }
}
